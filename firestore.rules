rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read any profile but only write their own
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Allow AI chats to be read/written for now to bypass strict auth checks in development
    match /ai_chats/{chatId} {
      allow read, write: if true;
    }

    match /notes/{noteId} {
      allow read, write: if true;
    }

    // Default rule for any other collections
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
